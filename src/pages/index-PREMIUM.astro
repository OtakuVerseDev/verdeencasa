---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getArticleImage } from '../utils/images';
import Hero from '../components/Hero.astro';

const allPosts = await getCollection('blog');
const recentPosts = allPosts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()).slice(0, 6);
const postHref = (id: string) => `/blog/${id.replace(/\.md$/, '')}/`;

const categories = [
  { name: 'Guías de cuidado', slug: 'guias', icon: '🌱', desc: 'Aprende paso a paso a cuidar cada tipo de planta' },
  { name: 'Problemas y enfermedades', slug: 'problemas', icon: '🔍', desc: 'Diagnostica y resuelve los problemas más comunes' },
  { name: 'Tipos de plantas', slug: 'tipos', icon: '🪴', desc: 'Descubre la planta perfecta para tu hogar' },
];
---

<BaseLayout
  title="VerdeEnCasa — Guía completa de cuidado de plantas de interior 2026"
  description="Aprende a cuidar plantas de interior con +30 guías completas. Soluciones a hojas amarillas, riego, luz, plagas. Todo en español. Consejos prácticos para principiantes y expertos."
>
  <!-- Hero Section - Editorial Premium -->

  <Hero title="Cómo cuidar plantas de interior: guía definitiva" lead="Más de 30 guías completas para mantener tus plantas sanas. Desde solucionar hojas amarillas hasta dominar el riego perfecto. Todo en español, explicado con claridad." />

  <!-- Stats Bar -->
  <section class="stats-bar">
    <div class="container-wide">
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-number">31</span>
          <span class="stat-label">Artículos detallados</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">124k</span>
          <span class="stat-label">Palabras de contenido</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">100%</span>
          <span class="stat-label">En español</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Trust Us - Refined -->
  <section class="trust-section">
    <div class="container">
      <h2 class="section-title">Por qué confiar en VerdeEnCasa</h2>
      
      <div class="trust-grid">
        <article class="trust-card">
          <div class="trust-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          <h3 class="trust-title">Guías verificadas</h3>
          <p class="trust-desc">Cada artículo está respaldado por investigación y experiencia real con plantas de interior.</p>
        </article>

        <article class="trust-card">
          <div class="trust-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="2" y1="12" x2="22" y2="12"></line>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
            </svg>
          </div>
          <h3 class="trust-title">Adaptado a España</h3>
          <p class="trust-desc">Contenido específico para el clima, condiciones y plantas disponibles en España y Latinoamérica.</p>
        </article>

        <article class="trust-card">
          <div class="trust-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
          </div>
          <h3 class="trust-title">Soluciones prácticas</h3>
          <p class="trust-desc">Sin tecnicismos innecesarios. Te decimos qué hacer y cómo hacerlo, paso a paso.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Categories - Editorial Grid -->
  <section class="categories-section">
    <div class="container">
      <h2 class="section-title">Explora por categoría</h2>
      <p class="section-subtitle">Encuentra exactamente lo que necesitas para tus plantas</p>
      
      <div class="categories-grid">
        {categories.map(cat => (
          <a href={`/${cat.slug}/`} class="category-card">
            <span class="category-icon">{cat.icon}</span>
            <h3 class="category-title">{cat.name}</h3>
            <p class="category-desc">{cat.desc}</p>
            <span class="category-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Recent Articles - Magazine Style -->
  <section class="articles-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Artículos recientes</h2>
        <a href="/blog/" class="view-all">Ver todos →</a>
      </div>

      <div class="articles-grid">
        {recentPosts.map(post => (
          <article class="article-card">
            <a href={postHref(post.id)} class="article-link">
                <div class="article-image">
                 <img src={getArticleImage(post.id)} alt={post.data.title} loading="lazy" decoding="async" width="800" height="400" />
               </div>
              <div class="article-content">
                <span class="article-category">{post.data.category}</span>
                <h3 class="article-title">{post.data.title}</h3>
                <p class="article-excerpt">{post.data.description}</p>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Problems Quick Access -->
  <section class="problems-section">
    <div class="container">
      <h2 class="section-title">Problemas más frecuentes</h2>
      <p class="section-subtitle">Encuentra la solución rápida a los síntomas que más afectan a tus plantas</p>
      
      <div class="problems-grid">
        <a href="/blog/hojas-amarillas-pothos/" class="problem-card">
          <span class="problem-emoji">🟡</span>
          <h3 class="problem-title">Hojas amarillas</h3>
          <p class="problem-hint">Por qué aparecen y cómo solucionarlo</p>
        </a>

        <a href="/blog/por-que-se-caen-hojas-planta/" class="problem-card">
          <span class="problem-emoji">🍂</span>
          <h3 class="problem-title">Hojas que se caen</h3>
          <p class="problem-hint">7 causas comunes y soluciones</p>
        </a>

        <a href="/blog/manchas-marrones-hojas-plantas/" class="problem-card">
          <span class="problem-emoji">🟤</span>
          <h3 class="problem-title">Manchas marrones</h3>
          <p class="problem-hint">Diagnóstico y tratamiento</p>
        </a>

        <a href="/blog/eliminar-plagas-plantas-interior/" class="problem-card">
          <span class="problem-emoji">🐛</span>
          <h3 class="problem-title">Plagas</h3>
          <p class="problem-hint">Cómo identificar y eliminar</p>
        </a>

        <a href="/blog/hojas-secas-puntas-marrones/" class="problem-card">
          <span class="problem-emoji">🔥</span>
          <h3 class="problem-title">Puntas secas</h3>
          <p class="problem-hint">Causas y prevención</p>
        </a>

        <a href="/blog/planta-no-crece-causas/" class="problem-card">
          <span class="problem-emoji">📉</span>
          <h3 class="problem-title">No crece</h3>
          <p class="problem-hint">10 razones y soluciones</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section - Minimal -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2 class="cta-title">¿Tu planta tiene un problema que no encuentras?</h2>
        <p class="cta-subtitle">Explora todas nuestras guías de diagnóstico y solución</p>
        <a href="/problemas/" class="btn-solid">Ver problemas y soluciones</a>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq-section">
    <div class="container">
      <h2 class="section-title">Preguntas frecuentes</h2>
      
      <div class="faq-list">
        <details class="faq-item">
          <summary class="faq-question">¿Cuántas veces a la semana debo regar mis plantas?</summary>
          <div class="faq-answer">
            <p>No existe una frecuencia universal. Depende del tipo de planta, la época del año, la humedad y la luz. La regla de oro es tocar la tierra: riega solo cuando los primeros 3-5 cm estén secos. En verano puede ser cada 4-7 días, en invierno cada 10-14 días.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">¿Por qué las hojas de mi planta se ponen amarillas?</summary>
          <div class="faq-answer">
            <p>Las hojas amarillas suelen indicar riego excesivo (causa #1), falta de luz, o falta de nutrientes. Si caen hojas amarillas desde abajo, probablemente estás regando demasiado. Lee nuestra <a href="/blog/hojas-amarillas-pothos/">guía sobre hojas amarillas</a> para diagnosticar la causa exacta.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">¿Qué planta es buena para principiantes?</summary>
          <div class="faq-answer">
            <p>Las mejores plantas para empezar son pothos, sansevieria (lengua de suegra), cactus, zamioculca y cinta. Todas toleran descuidos, poca luz y riegos irregulares. Consulta nuestra guía de <a href="/blog/plantas-interior-faciles-principiantes/">plantas fáciles para principiantes</a>.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">¿Las plantas necesitan sol directo?</summary>
          <div class="faq-answer">
            <p>La mayoría de plantas de interior prefieren luz indirecta brillante, no sol directo. El sol directo puede quemar las hojas. Excepciones: cactus, suculentas y algunas plantas tropicales sí toleran sol directo. Si ves manchas marrones en las hojas, probablemente hay demasiado sol.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Cuántas veces a la semana debo regar mis plantas?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No existe una frecuencia universal. Depende del tipo de planta, la época del año, la humedad y la luz. La regla de oro es tocar la tierra: riega solo cuando los primeros 3-5 cm estén secos."
        }
      },
      {
        "@type": "Question",
        "name": "¿Por qué las hojas de mi planta se ponen amarillas?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Las hojas amarillas suelen indicar riego excesivo, falta de luz, o falta de nutrientes."
        }
      },
      {
        "@type": "Question",
        "name": "¿Qué planta es buena para principiantes?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Las mejores plantas para empezar son pothos, sansevieria, cactus, zamioculca y cinta. Todas toleran descuidos."
        }
      },
      {
        "@type": "Question",
        "name": "¿Las plantas necesitan sol directo?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "La mayoría prefieren luz indirecta brillante. El sol directo puede quemar las hojas, excepto cactus y suculentas."
        }
      }
    ]
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "VerdeEnCasa",
    "url": "https://verdeencasa.es",
    "description": "Guía completa de cuidado de plantas de interior en español.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://verdeencasa.es/blog/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
</BaseLayout>

<style>
  /* Premium Editorial Design System */
  
  /* Hero Section - Clean & Editorial */
