---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getArticleImage } from '../utils/images';
import Hero from '../components/Hero.astro';

const allPosts = await getCollection('blog');
const recentPosts = allPosts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()).slice(0, 6);

const categories = [
  { name: 'Guías de cuidado', slug: 'guias', icon: '📘', desc: 'Aprende paso a paso a cuidar cada tipo de planta' },
  { name: 'Problemas y enfermedades', slug: 'problemas', icon: '🔍', desc: 'Diagnostica y resuelve los problemas más comunes' },
  { name: 'Tipos de plantas', slug: 'tipos', icon: '🪴', desc: 'Descubre la planta perfecta para tu hogar' },
];
---

<BaseLayout
  title="VerdeEnCasa — Guía completa de cuidado de plantas de interior 2026"
  description="Aprende a cuidar plantas de interior con +30 guías completas. Soluciones a hojas amarillas, riego, luz, plagas. Todo en español. Consejos prácticos para principiantes y expertos."
>
  <!-- Hero -->
  <Hero title="🌿 Cómo cuidar plantas de interior: guía completa 2026" lead="Más de 30 guías paso a paso para cuidar plantas de interior. Aprende a resolver hojas amarillas, riego correcto, trasplante, plagas y mucho más. Todo en español y gratis." />

  <!-- Por qué confiar en nosotros -->
  <section style="padding: 4rem 0 2rem; background: #fff;">
    <div class="container--wide">
      <h2 style="font-size:1.8rem; font-weight:800; text-align:center; margin-bottom:3rem; color:#0a0a0a;">¿Por qué VerdeEnCasa?</h2>
      <div class="features-grid">
        <div class="feature-box">
          <div class="feature-icon">✅</div>
          <h3>Guías verificadas</h3>
          <p>Cada artículo está respaldado por investigación y experiencia real con plantas de interior.</p>
        </div>
        <div class="feature-box">
          <div class="feature-icon">🇪🇸</div>
          <h3>100% en español</h3>
          <p>Adaptado al clima, las condiciones y las plantas disponibles en España y Latinoamérica.</p>
        </div>
        <div class="feature-box">
          <div class="feature-icon">💡</div>
          <h3>Soluciones prácticas</h3>
          <p>Sin tecnicismos innecesarios. Te decimos qué hacer y cómo hacerlo, paso a paso.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Categorías -->
  <section style="padding: 3rem 0; background: #fafafa;">
    <div class="container--wide">
      <h2 style="font-size:1.8rem; font-weight:800; margin-bottom:0.75rem; color:#0a0a0a;">Explora por categoría</h2>
      <p style="color:#737373; margin-bottom:2.5rem; font-size:1.05rem;">Encuentra exactamente lo que necesitas para tus plantas</p>
      <div class="cards-grid">
        {categories.map(cat => (
          <a href={`/${cat.slug}/`} style="text-decoration:none;">
            <div class="card">
              <div class="card-image">{cat.icon}</div>
              <div class="card-body">
                <h3 class="card-title">{cat.name}</h3>
                <p class="card-excerpt">{cat.desc}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Artículos recientes -->
  <section style="padding: 4rem 0; background: #fff;">
    <div class="container--wide">
      <h2 style="font-size:1.8rem; font-weight:800; margin-bottom:0.75rem; color:#0a0a0a;">Artículos recientes</h2>
      <p style="color:#737373; margin-bottom:2.5rem; font-size:1.05rem;">Las últimas guías y soluciones para tus plantas</p>
      <div class="cards-grid">
        {recentPosts.map(post => (
          <a href={`/blog/${post.id}/`} style="text-decoration:none;">
            <div class="card">
              <div class="card-image" style={`background-image: url('${getArticleImage(post.id)}'); background-size: cover; background-position: center; height: 200px; border-radius: 12px 12px 0 0;`}></div>
              <div class="card-body">
                <span class="card-tag">{post.data.category}</span>
                <p class="card-title">{post.data.title}</p>
                <p class="card-excerpt">{post.data.description}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section style="padding: 4rem 1.5rem; background: linear-gradient(135deg, #d1fae5 0%, #6ee7b7 100%); text-align: center;">
    <div style="max-width: 700px; margin: 0 auto;">
      <h2 style="font-size:2rem; font-weight:800; color:#064e3b; margin-bottom:1rem;">¿Tu planta tiene un problema?</h2>
      <p style="font-size:1.1rem; color:#065f46; margin-bottom:2rem;">Más de 30 guías detalladas con soluciones paso a paso para los problemas más comunes.</p>
      <a href="/problemas/" class="btn btn-primary">Ver problemas y soluciones</a>
    </div>
  </section>

  <!-- Problemas más buscados -->
  <section style="padding: 4rem 0; background: #fff;">
    <div class="container">
      <h2 style="font-size:1.8rem; font-weight:800; margin-bottom:0.75rem; color:#0a0a0a; text-align:center;">Problemas más frecuentes en plantas de interior</h2>
      <p style="color:#737373; margin-bottom:3rem; font-size:1.05rem; text-align:center;">Encuentra la solución rápida a los problemas que más afectan a tus plantas</p>
      
      <div style="max-width:900px; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:1.5rem;">
        <a href="/blog/hojas-amarillas-pothos/" style="padding:1.5rem; background:#f9fafb; border-radius:12px; border:2px solid #e5e7eb; text-decoration:none; transition:all 0.2s;" onmouseover="this.style.borderColor='#059669'" onmouseout="this.style.borderColor='#e5e7eb'">
          <h3 style="font-size:1.1rem; font-weight:700; color:#0a0a0a; margin-bottom:0.5rem;">🟡 Hojas amarillas</h3>
          <p style="color:#6b7280; font-size:0.9rem; margin:0;">Por qué aparecen y cómo solucionarlo →</p>
        </a>
        
        <a href="/blog/por-que-se-caen-hojas-planta/" style="padding:1.5rem; background:#f9fafb; border-radius:12px; border:2px solid #e5e7eb; text-decoration:none; transition:all 0.2s;" onmouseover="this.style.borderColor='#059669'" onmouseout="this.style.borderColor='#e5e7eb'">
          <h3 style="font-size:1.1rem; font-weight:700; color:#0a0a0a; margin-bottom:0.5rem;">🍂 Hojas que se caen</h3>
          <p style="color:#6b7280; font-size:0.9rem; margin:0;">7 causas comunes y soluciones →</p>
        </a>
        
        <a href="/blog/manchas-marrones-hojas-plantas/" style="padding:1.5rem; background:#f9fafb; border-radius:12px; border:2px solid #e5e7eb; text-decoration:none; transition:all 0.2s;" onmouseover="this.style.borderColor='#059669'" onmouseout="this.style.borderColor='#e5e7eb'">
          <h3 style="font-size:1.1rem; font-weight:700; color:#0a0a0a; margin-bottom:0.5rem;">🟤 Manchas marrones</h3>
          <p style="color:#6b7280; font-size:0.9rem; margin:0;">Diagnóstico y tratamiento →</p>
        </a>
        
        <a href="/blog/eliminar-plagas-plantas-interior/" style="padding:1.5rem; background:#f9fafb; border-radius:12px; border:2px solid #e5e7eb; text-decoration:none; transition:all 0.2s;" onmouseover="this.style.borderColor='#059669'" onmouseout="this.style.borderColor='#e5e7eb'">
          <h3 style="font-size:1.1rem; font-weight:700; color:#0a0a0a; margin-bottom:0.5rem;">🐛 Plagas</h3>
          <p style="color:#6b7280; font-size:0.9rem; margin:0;">Cómo identificar y eliminar →</p>
        </a>
        
        <a href="/blog/hojas-secas-puntas-marrones/" style="padding:1.5rem; background:#f9fafb; border-radius:12px; border:2px solid #e5e7eb; text-decoration:none; transition:all 0.2s;" onmouseover="this.style.borderColor='#059669'" onmouseout="this.style.borderColor='#e5e7eb'">
          <h3 style="font-size:1.1rem; font-weight:700; color:#0a0a0a; margin-bottom:0.5rem;">🔥 Puntas secas</h3>
          <p style="color:#6b7280; font-size:0.9rem; margin:0;">Causas y prevención →</p>
        </a>
        
        <a href="/blog/planta-no-crece-causas/" style="padding:1.5rem; background:#f9fafb; border-radius:12px; border:2px solid #e5e7eb; text-decoration:none; transition:all 0.2s;" onmouseover="this.style.borderColor='#059669'" onmouseout="this.style.borderColor='#e5e7eb'">
          <h3 style="font-size:1.1rem; font-weight:700; color:#0a0a0a; margin-bottom:0.5rem;">📉 No crece</h3>
          <p style="color:#6b7280; font-size:0.9rem; margin:0;">10 razones y soluciones →</p>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section style="padding: 4rem 0; background: #fff;">
    <div class="container">
      <h2 style="font-size:1.8rem; font-weight:800; margin-bottom:0.75rem; color:#0a0a0a; text-align:center;">Preguntas frecuentes</h2>
      <p style="color:#737373; margin-bottom:3rem; font-size:1.05rem; text-align:center;">Las respuestas a las dudas más comunes sobre plantas de interior</p>
      
      <div style="max-width:800px; margin:0 auto;">
        <div class="faq-item">
          <h3 style="font-size:1.15rem; font-weight:700; color:#0a0a0a; margin-bottom:0.75rem;">¿Cuántas veces a la semana debo regar mis plantas?</h3>
          <p style="color:#525252; line-height:1.7; margin-bottom:2rem;">No existe una frecuencia universal. Depende del tipo de planta, la época del año, la humedad y la luz. La regla de oro es tocar la tierra: riega solo cuando los primeros 3-5 cm estén secos. En verano puede ser cada 4-7 días, en invierno cada 10-14 días.</p>
        </div>

        <div class="faq-item">
          <h3 style="font-size:1.15rem; font-weight:700; color:#0a0a0a; margin-bottom:0.75rem;">¿Por qué las hojas de mi planta se ponen amarillas?</h3>
          <p style="color:#525252; line-height:1.7; margin-bottom:2rem;">Las hojas amarillas suelen indicar riego excesivo (causa #1), falta de luz, o falta de nutrientes. Si caen hojas amarillas desde abajo, probablemente estás regando demasiado. Lee nuestra guía sobre <a href="/blog/hojas-amarillas-pothos/" style="color:#059669; font-weight:600;">hojas amarillas en plantas</a> para diagnosticar la causa exacta.</p>
        </div>

        <div class="faq-item">
          <h3 style="font-size:1.15rem; font-weight:700; color:#0a0a0a; margin-bottom:0.75rem;">¿Qué planta es buena para principiantes?</h3>
          <p style="color:#525252; line-height:1.7; margin-bottom:2rem;">Las mejores plantas para empezar son pothos, sansevieria (lengua de suegra), cactus, zamioculca y cinta. Todas toleran descuidos, poca luz y riegos irregulares. Consulta nuestra lista completa de <a href="/blog/plantas-interior-faciles-principiantes/" style="color:#059669; font-weight:600;">plantas fáciles para principiantes</a>.</p>
        </div>

        <div class="faq-item">
          <h3 style="font-size:1.15rem; font-weight:700; color:#0a0a0a; margin-bottom:0.75rem;">¿Las plantas necesitan sol directo?</h3>
          <p style="color:#525252; line-height:1.7; margin-bottom:2rem;">La mayoría de plantas de interior prefieren luz indirecta brillante, no sol directo. El sol directo puede quemar las hojas. Excepciones: cactus, suculentas y algunas plantas tropicales sí toleran sol directo. Si ves manchas marrones en las hojas, probablemente hay demasiado sol.</p>
        </div>

        <div class="faq-item">
          <h3 style="font-size:1.15rem; font-weight:700; color:#0a0a0a; margin-bottom:0.75rem;">¿Cuándo debo trasplantar mi planta?</h3>
          <p style="color:#525252; line-height:1.7; margin-bottom:2rem;">Trasplanta cuando veas raíces saliendo por los agujeros de drenaje, cuando la tierra se seque muy rápido después de regar, o cuando la planta deje de crecer. La mejor época es primavera (marzo-mayo). Usa una maceta solo 2-3 cm más grande que la anterior. Lee nuestra <a href="/blog/como-trasplantar-plantas-interior/" style="color:#059669; font-weight:600;">guía completa de trasplante</a>.</p>
        </div>

        <div class="faq-item">
          <h3 style="font-size:1.15rem; font-weight:700; color:#0a0a0a; margin-bottom:0.75rem;">¿Cómo elimino plagas de forma natural?</h3>
          <p style="color:#525252; line-height:1.7; margin-bottom:2rem;">La mayoría de plagas se eliminan con jabón potásico diluido en agua (1 cucharada por litro) pulverizado cada 3-4 días. Para cochinillas, usa alcohol isopropílico con un bastoncillo. El aceite de neem es efectivo contra casi todas las plagas. Actúa rápido cuando detectes la primera plaga. Consulta nuestra <a href="/blog/eliminar-plagas-plantas-interior/" style="color:#059669; font-weight:600;">guía de eliminación de plagas</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Cuántas veces a la semana debo regar mis plantas?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No existe una frecuencia universal. Depende del tipo de planta, la época del año, la humedad y la luz. La regla de oro es tocar la tierra: riega solo cuando los primeros 3-5 cm estén secos. En verano puede ser cada 4-7 días, en invierno cada 10-14 días."
        }
      },
      {
        "@type": "Question",
        "name": "¿Por qué las hojas de mi planta se ponen amarillas?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Las hojas amarillas suelen indicar riego excesivo (causa #1), falta de luz, o falta de nutrientes. Si caen hojas amarillas desde abajo, probablemente estás regando demasiado."
        }
      },
      {
        "@type": "Question",
        "name": "¿Qué planta es buena para principiantes?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Las mejores plantas para empezar son pothos, sansevieria (lengua de suegra), cactus, zamioculca y cinta. Todas toleran descuidos, poca luz y riegos irregulares."
        }
      },
      {
        "@type": "Question",
        "name": "¿Las plantas necesitan sol directo?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "La mayoría de plantas de interior prefieren luz indirecta brillante, no sol directo. El sol directo puede quemar las hojas. Excepciones: cactus, suculentas y algunas plantas tropicales sí toleran sol directo."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuándo debo trasplantar mi planta?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Trasplanta cuando veas raíces saliendo por los agujeros de drenaje, cuando la tierra se seque muy rápido después de regar, o cuando la planta deje de crecer. La mejor época es primavera (marzo-mayo). Usa una maceta solo 2-3 cm más grande que la anterior."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cómo elimino plagas de forma natural?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "La mayoría de plagas se eliminan con jabón potásico diluido en agua (1 cucharada por litro) pulverizado cada 3-4 días. Para cochinillas, usa alcohol isopropílico con un bastoncillo. El aceite de neem es efectivo contra casi todas las plagas."
        }
      }
    ]
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "VerdeEnCasa",
    "url": "https://verdeencasa.es",
    "description": "Guía completa de cuidado de plantas de interior en español. Más de 30 artículos con soluciones prácticas.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://verdeencasa.es/blog/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
</BaseLayout>
