---
import HeroActions from './HeroActions.astro';
const { title = 'VerdeEnCasa — Guía completa de cuidado de plantas de interior', lead = '' } = Astro.props;
---

<section class="hero bg-white" aria-labelledby="hero-heading">
  <div class="max-w-7xl mx-auto grid gap-6 lg:grid-cols-[1fr_360px] items-center px-6 py-12">
    <div class="hero-left">
      <h1 id="hero-heading" class="font-display text-3xl sm:text-4xl lg:text-5xl leading-tight text-gray-900">{title}</h1>
      {lead && <p class="mt-4 text-lg text-gray-700">{lead}</p>}
      <div class="mt-6"><HeroActions /></div>
    </div>

    <div class="hero-right justify-self-end" role="img" aria-hidden="true">
      <picture>
        <source type="image/webp" srcset="/og/hero-1200x630.webp 1200w, /og/hero-800x420.webp 800w" />
        <source type="image/jpeg" srcset="/og/hero-1200x630.jpg 1200w, /og/hero-800x420.jpg 800w" />
        <img src="/og/hero-1200x630.webp" alt="" width="1200" height="630" loading="eager" decoding="async" fetchpriority="high" class="w-full h-auto rounded-lg shadow-lg" />
      </picture>
    </div>
  </div>
</section>
