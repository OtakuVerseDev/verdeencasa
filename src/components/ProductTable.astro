---
// src/components/ProductTable.astro
// Tabla comparativa de productos para máxima conversión
export interface Product {
  name: string;
  image: string;
  price: string;
  rating: number;
  highlight?: string;
  pros: string[];
  link: string;
}

export interface Props {
  title?: string;
  products: Product[];
}

const { title = "Productos recomendados", products } = Astro.props;
---

<div class="product-table-wrapper bg-gradient-to-br from-green-50 to-green-100 border-2 border-green-100 rounded-2xl p-6 my-8">
  <h3 class="table-title text-center text-2xl font-bold text-green-900 mb-6">{title}</h3>
  
  <div class="products-grid grid gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
    {products.map(product => (
      <div class="product-column bg-white rounded-xl p-5 text-center relative flex flex-col">
        {product.highlight && (
          <div class="column-badge absolute -top-3 left-1/2 transform -translate-x-1/2 bg-gradient-to-r from-amber-500 to-amber-600 text-white text-xs font-bold px-3 py-1 rounded-full">{product.highlight}</div>
        )}
        
        <div class="column-image bg-gray-50 rounded-md p-4 mb-3 h-44 flex items-center justify-center">
          <picture>
            <source type="image/webp" srcset={product.image.replace(/\.(jpg|png)$/i, '.webp')} />
            <img src={product.image} alt={product.name} loading="lazy" decoding="async" class="max-h-full max-w-full object-contain" />
          </picture>
        </div>
        
        <h4 class="column-name text-base font-semibold text-gray-900 mb-2 min-h-[2.6em]">{product.name}</h4>
        
        <div class="column-rating mb-2">
          <span class="stars text-amber-400">{'★'.repeat(product.rating)}{'☆'.repeat(5 - product.rating)}</span>
        </div>
        
        <div class="column-price text-xl font-extrabold text-green-700 mb-3">{product.price}</div>
        
        <ul class="column-pros text-left text-sm text-gray-700 mb-4 flex-grow">
          {product.pros.map(pro => <li class="py-1">✓ {pro}</li>)}
        </ul>
        
        <a href={product.link} target="_blank" rel="nofollow sponsored" class="column-cta mt-auto bg-accent text-white py-2 px-3 rounded-md font-semibold shadow-sm hover:bg-green-700">Ver en Amazon</a>
      </div>
    ))}
  </div>
  
  <p class="disclaimer text-center text-sm text-gray-600 italic mt-6">
    💡 Los precios pueden variar. Última actualización: {new Date().toLocaleDateString('es-ES', { year: 'numeric', month: 'long' })}.
  </p>
</div>

<style>
  .product-table-wrapper {
    background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 100%);
    border: 2px solid #d1fae5;
    border-radius: 16px;
    padding: 2rem;
    margin: 2.5rem 0;
  }
  
  .table-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #064e3b;
    text-align: center;
    margin-bottom: 2rem;
  }
  
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }
  
  .product-column {
    background: #fff;
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
    position: relative;
    border: 2px solid transparent;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  
  .product-column:hover {
    border-color: #375A47;
    box-shadow: 0 8px 20px rgba(5,150,105,0.15);
    transform: translateY(-4px);
  }
  
  .column-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.35rem 1rem;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    white-space: nowrap;
    box-shadow: 0 3px 10px rgba(245,158,11,0.4);
  }
  
  .column-image {
    background: #f9fafb;
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 1rem;
    height: 180px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .column-image img {
    max-height: 100%;
    max-width: 100%;
    object-fit: contain;
  }
  
  .column-name {
    font-size: 1rem;
    font-weight: 600;
    color: #111827;
    margin-bottom: 0.75rem;
    line-height: 1.3;
    min-height: 2.6em;
  }
  
  .column-rating {
    margin-bottom: 0.5rem;
  }
  
  .stars {
    color: #fbbf24;
    font-size: 1rem;
    letter-spacing: 2px;
  }
  
  .column-price {
    font-size: 1.75rem;
    font-weight: 800;
    color: #047857;
    margin: 0.75rem 0;
  }
  
  .column-pros {
    list-style: none;
    padding: 0;
    margin: 1rem 0;
    text-align: left;
    font-size: 0.85rem;
    color: #374151;
    flex-grow: 1;
  }
  
  .column-pros li {
    padding: 0.25rem 0;
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }
  
  .column-cta {
    background: #375A47;
    color: #fff;
    padding: 0.875rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
    display: block;
    margin-top: auto;
    box-shadow: 0 2px 8px rgba(5,150,105,0.3);
  }
  
  .column-cta:hover {
    background: #047857;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(5,150,105,0.4);
    color: #fff;
  }
  
  .disclaimer {
    text-align: center;
    font-size: 0.8rem;
    color: #6b7280;
    margin-top: 1.5rem;
    font-style: italic;
  }
  
  @media (max-width: 768px) {
    .product-table-wrapper {
      padding: 1.5rem 1rem;
    }
    
    .products-grid {
      grid-template-columns: 1fr;
    }
    
    .column-image {
      height: 150px;
    }
  }
</style>
