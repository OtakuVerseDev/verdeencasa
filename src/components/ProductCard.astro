---
// src/components/ProductCard.astro
// Tarjeta de producto Amazon optimizada para conversión
export interface Props {
  title: string;
  image: string;
  price?: string;
  rating?: number;
  reviews?: number;
  link: string;
  highlight?: string;
  pros?: string[];
}

const { title, image, price, rating, reviews, link, highlight, pros } = Astro.props;
---

<div class="product-card bg-white border border-gray-200 rounded-xl p-6 relative shadow-sm hover:shadow-lg transform transition-transform hover:-translate-y-1">
  {highlight && <div class="product-badge absolute -top-2 right-4 bg-gradient-to-r from-amber-400 to-yellow-500 text-white text-xs font-bold px-3 py-1 rounded-full">{highlight}</div>}

  <div class="product-image-wrapper bg-gray-50 rounded-md p-6 mb-4 text-center">
    <picture>
      <source type="image/webp" srcset={image.replace(/\.(jpg|png)$/i, '.webp')} />
      <img src={image} alt={title} class="product-image max-h-48 mx-auto object-contain" loading="lazy" decoding="async" />
    </picture>
  </div>

  <div class="product-body flex flex-col gap-3">
    <h3 class="product-title text-lg font-semibold text-gray-900">{title}</h3>
    
    {rating && (
      <div class="product-rating text-sm text-gray-600 flex items-center gap-2">
        <span class="stars text-amber-400">{'★'.repeat(Math.floor(rating))}{'☆'.repeat(5 - Math.floor(rating))}</span>
        {reviews && <span class="reviews text-xs text-gray-500">({reviews.toLocaleString('es-ES')} opiniones)</span>}
      </div>
    )}
    
    {price && <div class="product-price text-2xl font-extrabold text-green-700">{price}</div>}
    
    {pros && pros.length > 0 && (
      <ul class="product-pros list-none p-0 m-0 text-sm text-gray-700">
        {pros.map(pro => <li class="py-1">✓ {pro}</li>)}
      </ul>
    )}
    
    <a href={link} target="_blank" rel="nofollow sponsored" class="product-cta mt-4 inline-block bg-[color:var(--color-accent-primary)] text-white text-center py-3 px-4 rounded-md font-semibold shadow-sm hover:bg-green-700">Ver en Amazon →</a>
  </div>
</div>

<!-- Keep minimal fallback styles for non-Tailwind environments -->
<style>
  .product-card{border-radius:12px}
  .product-image{max-height:200px}
</style>
